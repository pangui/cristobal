{
    "permissions": {
        "defaultMode": "bypassPermissions"
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/common/transcript-start.sh ccs"
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/common/transcript-close.sh"
                    }
                ]
            }
        ]
    }
}
